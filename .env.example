# PlacementIQ — local development (SQLite)
# Copy to .env and adjust as needed.
#
# Production / Docker templates:
#   .env.production.example  — PostgreSQL + S3 pilot deployment
#   .env.docker.example      — Docker Compose trial

# Database (SQLite demo — default for local dev)
DATABASE_URL="file:./dev.db"

# Session signing (32+ characters; required in production)
SESSION_SECRET="dev-secret-change-me-before-production-deploy-32chars"

# App
NODE_ENV="development"
APP_URL="http://localhost:3000"

# File storage — local disk (default)
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB="5"

# --- Supabase PostgreSQL (PlacementIQ uses Prisma, not the Supabase JS client) ---
# From Supabase → Project Settings → Database, copy:
#   DATABASE_URL  = Connection pooling URI (port 6543, ?pgbouncer=true)
#   DIRECT_URL    = Direct connection URI (port 5432) — for prisma db push / migrations
#
# Vercel + Supabase integration: if only POSTGRES_PRISMA_URL is injected, PlacementIQ
# maps it to DATABASE_URL automatically. You can still set DATABASE_URL explicitly.
# DATABASE_URL="postgres://..."
# DIRECT_URL="postgres://..."

# --- S3-compatible object storage (production resumes) ---
# STORAGE_PROVIDER="s3"
# S3_BUCKET="placementiq-resumes"
# S3_REGION="ap-south-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""   # optional — MinIO, R2, etc.
# S3_KEY_PREFIX="resumes"

# --- GitHub integration (optional) ---
# GITHUB_TOKEN=""
# GITHUB_API_BASE_URL="https://api.github.com"
# GITHUB_SYNC_REPO_LIMIT="20"
# GITHUB_SYNC_TIMEOUT_MS="10000"

# --- Coding platform API integrations ---
# INTEGRATION_SECRET=""   # 32+ chars; encrypts stored API credentials (falls back to SESSION_SECRET)
# CODEFORCES_API_BASE_URL="https://codeforces.com/api"
# HACKERRANK_API_BASE_URL="https://www.hackerrank.com/x/api/v3"
# HACKEREARTH_API_BASE_URL="https://api.hackerearth.com/partner/hackerearth"
# CODING_SYNC_REQUEST_DELAY_MS="500"
# CODING_SYNC_BULK_LIMIT="50"

# AI_PROVIDER="none"
# AI_PROVIDER="openai"
# OPENAI_API_KEY=""
# AI_MODEL="gpt-4o-mini"
