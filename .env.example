# PlacementIQ — Supabase PostgreSQL (recommended)
# Copy to .env and paste values from Supabase → Project Settings → API / Database.
#
# PlacementIQ uses Prisma + PostgreSQL (not the Supabase JS client).
# Prisma needs DATABASE_URL (pooled, port 6543) and DIRECT_URL (direct, port 5432).
# Vercel Supabase integration injects POSTGRES_* — auto-mapped if DATABASE_URL is unset.

# --- Prisma (required) ---
DATABASE_URL="postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# --- Supabase project (optional for core app; useful for future integrations) ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_JWT_SECRET=""

# --- Supabase Postgres (Vercel integration names — optional if DATABASE_URL is set) ---
POSTGRES_DATABASE="postgres"
POSTGRES_HOST="db.YOUR_PROJECT.supabase.co"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""

# Session signing (32+ characters; required in production)
SESSION_SECRET="dev-secret-change-me-before-production-deploy-32chars"

# App
NODE_ENV="development"
APP_URL="http://localhost:3000"

# File storage — local disk (default)
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB="5"

# --- SQLite (local-only alternative — change prisma/schema.prisma provider to sqlite) ---
# DATABASE_URL="file:./dev.db"

# --- S3-compatible object storage (production resumes) ---
# STORAGE_PROVIDER="s3"
# S3_BUCKET="placementiq-resumes"
# S3_REGION="ap-south-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""   # optional — MinIO, R2, etc.
# S3_KEY_PREFIX="resumes"

# --- GitHub integration (optional) ---
# GITHUB_TOKEN=""
# GITHUB_API_BASE_URL="https://api.github.com"
# GITHUB_SYNC_REPO_LIMIT="20"
# GITHUB_SYNC_TIMEOUT_MS="10000"

# --- Coding platform API integrations ---
# INTEGRATION_SECRET=""   # 32+ chars; encrypts stored API credentials (falls back to SESSION_SECRET)
# CODEFORCES_API_BASE_URL="https://codeforces.com/api"
# HACKERRANK_API_BASE_URL="https://www.hackerrank.com/x/api/v3"
# HACKEREARTH_API_BASE_URL="https://api.hackerearth.com/partner/hackerearth"
# CODING_SYNC_REQUEST_DELAY_MS="500"
# CODING_SYNC_BULK_LIMIT="50"

# AI_PROVIDER="none"
# AI_PROVIDER="openai"
# OPENAI_API_KEY=""
# AI_MODEL="gpt-4o-mini"
