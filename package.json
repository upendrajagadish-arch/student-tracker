{
  "name": "placementiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "vercel-build": "node scripts/prisma-generate.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "node scripts/run-prisma.mjs db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:large": "tsx scripts/seed-large-demo.ts",
    "db:setup": "node scripts/prisma-generate.mjs && prisma db push && tsx prisma/seed.ts",
    "smoke": "tsx scripts/smoke-check.ts",
    "smoke:production": "tsx scripts/production-smoke-check.ts",
    "pilot:smoke": "tsx scripts/pilot-smoke-check.ts",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "next": "^15.1.3",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
