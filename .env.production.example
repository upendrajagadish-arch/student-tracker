# PlacementIQ — production environment template
# Copy values into your host secrets manager or deployment platform.
# NEVER commit a real .env file with production secrets.

# --- Core ---
NODE_ENV=production
APP_URL=https://placementiq.example.edu

# --- Database (PostgreSQL required for production) ---
# 1. Set provider = "postgresql" in prisma/schema.prisma
# 2. Run: npx prisma migrate deploy
DATABASE_URL=postgresql://placementiq:CHANGE_ME@db-host:5432/placementiq?schema=public

# --- Session (32+ characters; generate a unique value) ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- File storage (S3 recommended for production) ---
STORAGE_PROVIDER=s3
S3_BUCKET=placementiq-files
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional — required for Cloudflare R2, MinIO, and other S3-compatible endpoints
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_KEY_PREFIX=placementiq

# Local disk fallback (single-instance / staging only — not for multi-instance production)
# STORAGE_PROVIDER=local
# LOCAL_UPLOAD_DIR=uploads

MAX_UPLOAD_SIZE_MB=5

# --- Scale / safety limits (optional — defaults shown) ---
EXPORT_ROW_LIMIT=5000
REPORT_ROW_LIMIT=500
PRINT_REPORT_ROW_LIMIT=200
BULK_READINESS_BATCH_SIZE=100
