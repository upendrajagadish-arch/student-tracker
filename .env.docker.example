# PlacementIQ — Docker Compose trial environment
# Copy to .env in the project root:  cp .env.docker.example .env
#
# Starts PostgreSQL + app with local file storage (uploads volume).
# For a production-like pilot, switch STORAGE_PROVIDER to s3 and set S3_* vars.

SESSION_SECRET=change-me-use-32-plus-char-secret-in-production

NODE_ENV=production
APP_URL=http://localhost:3000

DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://placementiq:placementiq@db:5432/placementiq?schema=public

# Docker trial uses local storage on a named volume (persists across restarts).
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- S3 (recommended for real production / multi-instance) ---
# STORAGE_PROVIDER=s3
# S3_BUCKET=placementiq-files
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_KEY_PREFIX=placementiq

EXPORT_ROW_LIMIT=5000
REPORT_ROW_LIMIT=500
PRINT_REPORT_ROW_LIMIT=200
BULK_READINESS_BATCH_SIZE=100
